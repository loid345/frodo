?>
<form action="<?= $escaper->escapeUrl($block->getSaveUrl()) ?>" method="post" id="frodo_antifraud_add_form">
    <?= $block->getBlockHtml('formkey') ?>
    <fieldset class="admin__fieldset">
        <?php foreach ($block->getFields() as $fieldName => $fieldConfig): ?>
            <div class="admin__field<?= !empty($fieldConfig['required']) ? ' _required' : '' ?>">
                <label class="admin__field-label" for="<?= $escaper->escapeHtmlAttr($fieldName) ?>">
                    <span><?= $escaper->escapeHtml(__($fieldConfig['label'] ?? $fieldName)) ?></span>
                </label>
                <div class="admin__field-control">
                    <input type="<?= $escaper->escapeHtmlAttr($fieldConfig['type'] ?? 'text') ?>"
                           name="<?= $escaper->escapeHtmlAttr($fieldName) ?>"
                           id="<?= $escaper->escapeHtmlAttr($fieldName) ?>"
                           class="admin__control-text"
                           <?= !empty($fieldConfig['required']) ? 'required' : '' ?>/>
                    <?php if (!empty($fieldConfig['note'])): ?>
                        <div class="admin__field-note">
                            <span><?= $escaper->escapeHtml(__($fieldConfig['note'])) ?></span>
                        </div>
                    <?php endif; ?>
                </div>
            </div>
        <?php endforeach; ?>
    </fieldset>
    <div class="admin__page-actions">
        <button type="button"
                class="action-default scalable back"
                onclick="location.href='<?= $escaper->escapeUrl($block->getBackUrl()) ?>'">
            <span><?= $escaper->escapeHtml(__('Back')) ?></span>
        </button>
        <button type="submit" class="action-default scalable save primary">
            <span><?= $escaper->escapeHtml(__('Save')) ?></span>
        </button>
    </div>
</form>
