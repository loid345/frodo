<?xml version="1.0"?>
<listing xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">frodo_antifraud_blacklist_email_listing.frodo_antifraud_blacklist_email_listing_data_source</item>
        </item>
    </argument>
    <settings>
        <buttons>
            <button name="add">
                <url path="*/*/newAction"/>
                <class>primary</class>
                <label translate="true">Add Email</label>
            </button>
        </buttons>
        <spinner>frodo_antifraud_blacklist_email_columns</spinner>
        <deps>
            <dep>frodo_antifraud_blacklist_email_listing.frodo_antifraud_blacklist_email_listing_data_source</dep>
        </deps>
    </settings>
    <dataSource name="frodo_antifraud_blacklist_email_listing_data_source" component="Magento_Ui/js/grid/provider">
        <settings>
            <updateUrl path="mui/index/render"/>
        </settings>
        <aclResource>Frodo_Antifraud::lists</aclResource>
        <dataProvider class="FrodoAntifraudBlacklistEmailGridDataProvider" name="frodo_antifraud_blacklist_email_listing_data_source">
            <settings>
                <requestFieldName>entity_id</requestFieldName>
                <primaryFieldName>entity_id</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>
    <listingToolbar name="listing_top">
        <settings>
            <sticky>true</sticky>
        </settings>
        <bookmark name="bookmarks"/>
        <columnsControls name="columns_controls"/>
        <filters name="listing_filters"/>
        <massaction name="listing_massaction">
            <action name="delete">
                <settings>
                    <url path="frodo_antifraud/blacklistEmail/massDelete"/>
                    <type>delete</type>
                    <label translate="true">Delete</label>
                    <confirm>
                        <title translate="true">Delete entries</title>
                        <message translate="true">Are you sure you want to delete selected entries?</message>
                    </confirm>
                </settings>
            </action>
        </massaction>
        <paging name="listing_paging"/>
        <exportButton name="export_button"/>
    </listingToolbar>
    <columns name="frodo_antifraud_blacklist_email_columns">
        <selectionsColumn name="ids" sortOrder="10">
            <settings>
                <indexField>entity_id</indexField>
            </settings>
        </selectionsColumn>
        <column name="entity_id" sortOrder="20">
            <settings>
                <filter>textRange</filter>
                <label translate="true">ID</label>
                <sorting>desc</sorting>
            </settings>
        </column>
        <column name="email" sortOrder="30">
            <settings>
                <filter>text</filter>
                <label translate="true">Email</label>
            </settings>
        </column>
        <column name="reason" sortOrder="40">
            <settings>
                <filter>text</filter>
                <label translate="true">Reason</label>
            </settings>
        </column>
        <column name="created_at" class="Magento\Ui\Component\Listing\Columns\Date" component="Magento_Ui/js/grid/columns/date" sortOrder="50">
            <settings>
                <filter>dateRange</filter>
                <label translate="true">Created At</label>
                <dataType>date</dataType>
            </settings>
        </column>
        <actionsColumn name="actions" class="Frodo\Antifraud\Ui\Component\Listing\Column\ListActions" sortOrder="100">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="deleteUrlPath" xsi:type="string">frodo_antifraud/blacklistEmail/delete</item>
                    <item name="idFieldName" xsi:type="string">entity_id</item>
                </item>
            </argument>
            <settings>
                <indexField>entity_id</indexField>
            </settings>
        </actionsColumn>
    </columns>
</listing>
