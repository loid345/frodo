<?xml version="1.0"?>
<listing xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">frodo_antifraud_action_log_listing.frodo_antifraud_action_log_listing_data_source</item>
        </item>
    </argument>
    <settings>
        <spinner>frodo_antifraud_action_log_columns</spinner>
        <deps>
            <dep>frodo_antifraud_action_log_listing.frodo_antifraud_action_log_listing_data_source</dep>
        </deps>
    </settings>
    <dataSource name="frodo_antifraud_action_log_listing_data_source" component="Magento_Ui/js/grid/provider">
        <settings><updateUrl path="mui/index/render"/></settings>
        <aclResource>Frodo_Antifraud::action_log</aclResource>
        <dataProvider class="FrodoAntifraudActionLogGridDataProvider" name="frodo_antifraud_action_log_listing_data_source">
            <settings>
                <requestFieldName>entity_id</requestFieldName>
                <primaryFieldName>entity_id</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>
    <listingToolbar name="listing_top">
        <settings><sticky>true</sticky></settings>
        <bookmark name="bookmarks"/>
        <columnsControls name="columns_controls"/>
        <filters name="listing_filters"/>
        <paging name="listing_paging"/>
        <exportButton name="export_button"/>
    </listingToolbar>
    <columns name="frodo_antifraud_action_log_columns">
        <column name="entity_id" sortOrder="10">
            <settings><filter>textRange</filter><label translate="true">ID</label><sorting>desc</sorting></settings>
        </column>
        <column name="created_at" class="Magento\Ui\Component\Listing\Columns\Date" component="Magento_Ui/js/grid/columns/date" sortOrder="20">
            <settings><filter>dateRange</filter><label translate="true">Date</label><dataType>date</dataType></settings>
        </column>
        <column name="action_type" sortOrder="30">
            <settings>
                <filter>select</filter>
                <label translate="true">Action</label>
                <options class="Frodo\Antifraud\Ui\Component\Listing\Column\ActionTypeOptions"/>
                <dataType>select</dataType>
            </settings>
        </column>
        <column name="target_type" sortOrder="40">
            <settings><filter>select</filter><label translate="true">Target Type</label>
                <options class="Frodo\Antifraud\Ui\Component\Listing\Column\TargetTypeOptions"/>
                <dataType>select</dataType>
            </settings>
        </column>
        <column name="target_value" sortOrder="50">
            <settings><filter>text</filter><label translate="true">Target</label></settings>
        </column>
        <column name="admin_user_id" sortOrder="60">
            <settings><filter>text</filter><label translate="true">Admin User ID</label></settings>
        </column>
        <column name="customer_id" class="Frodo\Antifraud\Ui\Component\Listing\Column\CustomerLink" sortOrder="70">
            <settings><filter>text</filter><label translate="true">Customer</label></settings>
        </column>
        <column name="details" sortOrder="80">
            <settings><label translate="true">Details</label></settings>
        </column>
    </columns>
</listing>
