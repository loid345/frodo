<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <referenceContainer name="content">
            <block class="Frodo\Antifraud\Block\Adminhtml\GenericAddForm" name="frodo_antifraud_blacklist_email_add_form" template="Frodo_Antifraud::add_form.phtml">
                <arguments>
                    <argument name="save_url" xsi:type="string">frodo_antifraud/blacklistEmail/save</argument>
                    <argument name="back_url" xsi:type="string">frodo_antifraud/blacklistEmail/index</argument>
                    <argument name="fields" xsi:type="array">
                        <item name="email" xsi:type="array">
                            <item name="label" xsi:type="string">Email Address</item>
                            <item name="type" xsi:type="string">email</item>
                            <item name="required" xsi:type="boolean">true</item>
                        </item>
                        <item name="reason" xsi:type="array">
                            <item name="label" xsi:type="string">Reason</item>
                            <item name="type" xsi:type="string">text</item>
                            <item name="required" xsi:type="boolean">false</item>
                        </item>
                    </argument>
                </arguments>
            </block>
        </referenceContainer>
    </body>
</page>
