<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:Acl/etc/acl.xsd">
    <acl>
        <resources>
            <resource id="Magento_Backend::admin">
                <resource id="Frodo_Antifraud::antifraud" title="Frodo Antifraud" sortOrder="50">
                    <resource id="Frodo_Antifraud::lists" title="Manage Antifraud Lists" sortOrder="10"/>
                    <resource id="Frodo_Antifraud::action_log" title="View Action Log" sortOrder="20"/>
                </resource>
                <resource id="Magento_Backend::stores">
                    <resource id="Magento_Backend::stores_settings">
                        <resource id="Magento_Config::config">
                            <resource id="Frodo_Antifraud::config" title="Frodo Antifraud Configuration" sortOrder="10"/>
                        </resource>
                    </resource>
                </resource>
            </resource>
        </resources>
    </acl>
</config>
